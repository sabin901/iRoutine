# iRoutine Backend — copy to .env and fill in values
# All variables are required for the API to run.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# CORS (comma-separated origins; production: your frontend URL)
CORS_ORIGINS=http://localhost:3000

# Optional: chat-completions-compatible server for extended pattern narration
# Set BASE_URL to your server’s /v1 root; MODEL to the id that server expects.
LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL=http://127.0.0.1:8080/v1
LOCAL_LLM_MODEL=your-model-id
LOCAL_LLM_API_KEY=local
LOCAL_LLM_TIMEOUT_SECONDS=20
