# iRoutine Backend — copy to .env and fill in values
# All variables are required for the API to run.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# CORS (comma-separated origins; production: your frontend URL)
CORS_ORIGINS=http://localhost:3000

# Optional local/OpenAI-compatible LLM insights
# Ollama example: ollama pull nemotron-3-nano:30b && ollama serve
LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=nemotron-3-nano:30b
LOCAL_LLM_API_KEY=local
LOCAL_LLM_TIMEOUT_SECONDS=20
